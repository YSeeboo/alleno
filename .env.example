# 数据库（必填，必须是 PostgreSQL）
DATABASE_URL=postgresql://user:password@host:5432/allen_shop

# DeepSeek API（使用 Bot AI 功能时必填）
DEEPSEEK_API_KEY=

# 飞书 Bot（不使用 Bot 可留空）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 允许使用 Bot 的飞书用户 open_id，多个用逗号分隔，留空则不限制
FEISHU_WHITELIST=

# 阿里云 OSS（图片上传）
OSS_BUCKET=
OSS_REGION=
OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_PUBLIC_BASE_URL=
