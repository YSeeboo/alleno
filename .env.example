# 数据库（必填，必须是 PostgreSQL）
DATABASE_URL=postgresql://user:password@host:5432/allen_shop

# Telegram Bot（不使用 Bot 可留空）
TELEGRAM_BOT_TOKEN=
# 允许使用 Bot 的 Telegram 用户 ID，多个用逗号分隔，留空则不限制
TELEGRAM_WHITELIST=123456789,987654321
# 代理地址，不需要代理可留空
TELEGRAM_PROXY_URL=

# Anthropic（使用 Bot AI 功能时必填）
ANTHROPIC_API_KEY=
# 自定义 API 地址，使用官方接口可留空
ANTHROPIC_BASE_URL=
